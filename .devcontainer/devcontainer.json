{
    "name": "Strata Devcontainer",
    // Pre-built image from GHCR (built by .github/workflows/devcontainer.yml).
    // To build locally instead, comment out "image" and uncomment "build" below.
    "image": "ghcr.io/rephlexzero/strata/devcontainer:latest",
    // "build": {
    //     "dockerfile": "Dockerfile",
    //     "context": "..",
    //     "options": ["--network=host"]
    // },
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer",
                "tamasfe.even-better-toml",
                "vadimcn.vscode-lldb",
                "fill-labs.dependi",
                "github.vscode-github-actions",
                "GitHub.copilot-chat",
                "Anthropic.claude-code"
            ]
        }
    },
    // "privileged": true is required for ip netns creation (mount operations)
    "privileged": true,
    "capAdd": [
        "SYS_PTRACE",
        "NET_ADMIN"
    ],
    "securityOpt": [
        "seccomp=unconfined"
    ],
    "mounts": [
        "source=/lib/modules,target=/lib/modules,type=bind,readonly",
        // Expose all host device nodes (video*, bus/usb for LTE dongles, dri for VA-API).
        // Safe because the container is already privileged; avoids enumerating
        // individual /dev/videoN or /dev/bus/usb/... paths that change per-host.
        "source=/dev,target=/dev,type=bind",
        // Forward the host SSH agent socket so field-test.sh can reach the
        // receiver server using whatever identities are loaded on the host
        // (including hardware keys / YubiKeys) without copying key files.
        "source=${localEnv:SSH_AUTH_SOCK},target=/ssh-agent.sock,type=bind"
    ],
    // Tell the container where the forwarded agent socket lives.
    "containerEnv": {
        "SSH_AUTH_SOCK": "/ssh-agent.sock"
    },
    // GPU passthrough for hardware video encoding (VA-API: AMD / Intel).
    // /dev/dri is already covered by the /dev bind mount above; kept as an
    // explicit hint so the container engine knows to allow the cgroup entry
    // even on hosts that start the container before the bind mount applies.
    //
    // --network=host: share the host's network namespace so that LTE modem
    // interfaces (enp2s0f0u3, enp2s0f0u4, etc.) are visible inside the
    // container for the field test. Without this they live only in the host
    // netns and are invisible to ip(8) inside the container.
    "runArgs": [
        "--device=/dev/dri",
        "--network=host"
    ],
    "features": {
        "ghcr.io/devcontainers/features/rust:1": {},
        "ghcr.io/devcontainers/features/docker-in-docker:2": {}
    },
    "postCreateCommand": ".devcontainer/post-create.sh",
    "postStartCommand": ".devcontainer/post-start.sh"
}