#!/usr/bin/env bash
set -euo pipefail

# Pre-push: verify format wasn't bypassed with --no-verify.
# Tests already ran in pre-commit, so we just double-check format + lint.

echo "[pre-push] Format check..."
cargo fmt --all -- --check

echo "[pre-push] Clippy..."
cargo clippy --workspace --all-targets -- -D warnings

echo "[pre-push] ✓ All checks passed"
exit 0
