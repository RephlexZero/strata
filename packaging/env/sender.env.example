# /etc/strata/sender.env — strata-sender configuration
#
# STRATA_SENDER_ARGS holds the clap flags passed verbatim to strata-sender.
# systemd word-splits on whitespace; do NOT quote individual flags.
#
# Common flags:
#   --control-url <ws[s]://host[:port]/agent/ws>   control plane WebSocket
#   --enrollment-token <TOKEN>                     one-time enrollment token
#   --identity-file <path>       default /var/lib/strata/sender-identity.json
#   --portal-addr <addr:port>    local portal, default :3001
#   --metrics-addr <addr:port>   Prometheus metrics listener (optional)

STRATA_SENDER_ARGS=--control-url wss://control.example.com/agent/ws --enrollment-token CHANGE-ME

# Logging verbosity
RUST_LOG=info

# Only needed if libgststrata.so is NOT in the system GStreamer plugin dir
# (install.sh puts it there; the fallback path needs this):
#GST_PLUGIN_PATH=/usr/local/lib/gstreamer-1.0
