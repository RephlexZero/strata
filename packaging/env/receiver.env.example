# /etc/strata/receiver.env — strata-receiver configuration
#
# STRATA_RECEIVER_ARGS holds the clap flags passed verbatim to strata-receiver.
# systemd word-splits on whitespace; do NOT quote individual flags.
#
# Common flags:
#   --control-url <ws[s]://host[:port]/receiver/ws>  control plane WebSocket
#   --enrollment-token <TOKEN>                       one-time enrollment token
#   --identity-file <path>      default /var/lib/strata/receiver-identity.json
#   --bind-host <host>          public host/IP senders dial (env: BIND_HOST)
#   --link-ports <p1,p2,...>    UDP ports, one per bonded link (open in firewall!)
#   --max-streams <n>           concurrent stream capacity

STRATA_RECEIVER_ARGS=--control-url wss://control.example.com/receiver/ws --enrollment-token CHANGE-ME --bind-host receiver.example.com --link-ports 5000,5002,5004 --max-streams 4

# Alternative to --bind-host:
#BIND_HOST=receiver.example.com

# Logging verbosity
RUST_LOG=info

# Only needed if libgststrata.so is NOT in the system GStreamer plugin dir:
#GST_PLUGIN_PATH=/usr/local/lib/gstreamer-1.0
