# /etc/strata/control.env — strata-control configuration
# strata-control is configured entirely via environment variables.
# Keep this file root-owned, mode 0600 — it contains secrets.

# PostgreSQL connection (required)
DATABASE_URL=postgres://strata:CHANGE-ME@localhost/strata

# Listen address. Bind loopback and terminate TLS at a reverse proxy
# (see packaging/caddy/Caddyfile.example).
LISTEN_ADDR=127.0.0.1:3000

# JWT signing seed (required in production — without it an ephemeral key is
# generated and all tokens die on restart). Generate with:
#   head -c32 /dev/urandom | base64
JWT_SEED_B64=CHANGE-ME

# Static dashboard assets (as laid out by the release tarball / Docker image)
#DASHBOARD_DIR=/usr/local/share/strata/dashboard

# Bearer token protecting the Prometheus /metrics endpoint.
# Presence matters: leave commented to disable auth, do not set it empty.
#METRICS_TOKEN=CHANGE-ME

# CORS opt-in for cross-origin dashboards. Comma-separated origins, or "*"
# (permissive — never with internet exposure). Presence matters: leave
# commented for the default no-CORS behaviour; an empty value is invalid.
#CORS_ALLOWED_ORIGINS=https://dash.example.com

# Close /api/auth/register once the operator accounts exist. Role checks
# are not implemented yet, so ANY registered account can drive the fleet —
# never leave registration open on an internet-facing deployment.
#DISABLE_REGISTRATION=1

# Logging verbosity
RUST_LOG=info,strata_control=info
